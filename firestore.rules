rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: holerites
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - employeeName: string (required)
    //   - netPay: number (required)
    //   - createdAt: timestamp (required)
    //   ... other holerite fields
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidHolerite(data) {
      return data.userId is string &&
             data.employeeName is string && data.employeeName.size() > 0 && data.employeeName.size() < 200 &&
             data.netPay is number &&
             data.createdAt is timestamp;
    }

    match /holerites/{holeriteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && isValidHolerite(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId) && isValidHolerite(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
